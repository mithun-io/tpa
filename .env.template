# Database Configuration
# These should match the POSTGRES_DB, POSTGRES_USER, POSTGRES_PASSWORD in docker-compose.yml
DB_HOST=postgres
DB_PORT=5432
DB_NAME=tpadb
DB_USER=tpauser
DB_PASSWORD=tpapassword

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# Kafka Configuration
# Internal docker network uses 29092 for inter-broker communication in our setup
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# OpenAI API Key (IMPORTANT: Replace with your actual key)
OPENAI_API_KEY=YOUR_API_KEY_HERE

# JWT Configuration (generate a strong secret for production)
JWT_SECRET=your_super_secret_jwt_key_here_for_production_use
JWT_EXPIRATION=86400000

# Admin Default Credentials
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@tpa.com
ADMIN_MOBILE=1234567890
ADMIN_PASSWORD=admin
